{
    "workbench.colorCustomizations": {
        "editor.background": "{{colors.surface.default.hex}}",
        "sideBar.background": "{{colors.surface.default.hex}}",
        "sideBar.border": "{{colors.surface.default.hex}}",
        "activityBar.background": "{{colors.surface.default.hex}}",
        "activityBar.border": "{{colors.surface.default.hex}}",
        "editorGroupHeader.tabsBackground": "{{colors.surface.default.hex}}",
        "editorGroupHeader.tabsBorder": "{{colors.surface.default.hex}}",
        "tab.activeBackground": "{{colors.surface.default.hex}}",
        "tab.activeBorder": "{{colors.primary.default.hex}}",
        "tab.inactiveBackground": "{{colors.surface.default.hex}}",
        "editorLineNumber.foreground": "{{colors.surface_container_high.default.hex}}",
        "editorLineNumber.activeForeground": "{{colors.primary.default.hex}}",
        "editorCursor.foreground": "{{colors.primary.default.hex}}",
        "editor.selectionBackground": "{{colors.primary_container.default.hex}}66"
    },

    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                // Balises HTML (p, div, html, doctype)
                "scope": [
                    "entity.name.tag",
                    "meta.tag.sgml.doctype.html",
                    "punctuation.definition.tag"
                ],
                "settings": {
                    "foreground": "{{colors.primary.default.hex}}",
                    "fontStyle": "bold"
                }
            },
            {
                // Attributs HTML (class, id, src)
                "scope": "entity.other.attribute-name",
                "settings": {
                    "foreground": "{{colors.secondary.default.hex}}"
                }
            },
            {
                // Texte à l'intérieur des balises
                "scope": "text.html.derivative",
                "settings": {
                    "foreground": "{{colors.on_surface.default.hex}}"
                }
            },
            {
                // Commentaires
                "scope": "comment",
                "settings": {
                    "foreground": "{{colors.outline.default.hex}}",
                    "fontStyle": "italic"
                }
            }
        ]
    },

    // --- Ton interface Minimaliste ---
    "workbench.activityBar.location": "hidden",
    "workbench.statusBar.visible": false,
    "editor.minimap.enabled": false,
    "editor.scrollbar.vertical": "hidden",
    "editor.glyphMargin": false,
    "editor.folding": false,
    "breadcrumbs.enabled": false,
    "workbench.editor.showTabs": "single",
    "window.menuBarVisibility": "toggle",
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "editor.lineNumbers": "on",
    "editor.fontFamily": "JetBrainsMono Nerd Font",
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.padding.top": 25,
    "workbench.iconTheme": "material-icon-theme",
    "workbench.productIconTheme": "material-product-icons"
}
